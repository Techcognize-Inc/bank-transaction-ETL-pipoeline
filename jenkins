pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                sh 'docker exec spark-worker pip install -r /var/jenkins_home/workspace/bank-tx-etl-pipeline/requirements.txt'
            }
        }

        stage('Run Spark Ingestion Job') {
            steps {
                sh 'docker exec spark-worker /opt/spark/bin/spark-submit /var/jenkins_home/workspace/bank-tx-etl-pipeline/spark_jobs/ingest.py'
            }
        }

    }
}